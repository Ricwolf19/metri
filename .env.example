# Master admin seed — used once, on first launch, when the users table is empty.
# Copy to `.env` (gitignored) and set real values. EXPO_PUBLIC_* vars are inlined
# into the JS bundle, so this is a convenience for local seeding, not a secret store.
EXPO_PUBLIC_ADMIN_EMAIL=admin@metri.app
EXPO_PUBLIC_ADMIN_USERNAME=admin
EXPO_PUBLIC_ADMIN_NAME=Metri Admin
EXPO_PUBLIC_ADMIN_PASSWORD=change-me
